# リストア元(MySQL)接続情報
SRC_HOST="127.0.0.1"
SRC_PORT="13306"
SRC_USER="root"
SRC_PASS="rootpass"
SRC_DB="testdb"

# リストア先(MariaDB)接続情報
DST_HOST="127.0.0.1"
DST_PORT="13307"
DST_USER="root"
DST_PASS="rootpass"
DST_DB="testdb"

# サンプル取得件数(先頭/末尾それぞれ)
SAMPLE_ROWS=5

# ダンプファイルパス
DUMP_FILE="dump.sql"

# スナップショット出力先
SNAPSHOT_DIR="snapshot"

# 検証結果出力先
VERIFY_DIR="verify_results"
