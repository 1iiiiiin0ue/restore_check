# リストア元(MySQL)接続情報
SRC_HOST="127.0.0.1"
SRC_PORT="13306"
SRC_USER="root"
SRC_PASS="rootpass"

# リストア先(MariaDB)接続情報
DST_HOST="127.0.0.1"
DST_PORT="13307"
DST_USER="root"
DST_PASS="rootpass"

# 対象データベース
# "--all": 全ユーザーDB(システムDB除外)
# "db1 db2 db3": スペース区切りで複数DB指定
# "testdb": 単一DB指定
TARGET_DBS="--all"

# サンプル取得件数(先頭/末尾それぞれ)
SAMPLE_ROWS=5

# ダンプ出力先ディレクトリ
DUMP_DIR="dump"

# スナップショット出力先
SNAPSHOT_DIR="snapshot"

# 検証結果出力先
VERIFY_DIR="verify_results"
